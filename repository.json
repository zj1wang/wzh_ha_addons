{
  "name": "WZH Home Assistant Add-ons",
  "url": "https://github.com/yourusername/wzh_ha_addons",
  "maintainer": "WZH",
  "addons": [
    {
      "name": "V2rayA",
      "version": "1.0.3",
      "slug": "v2raya",
      "description": "V2rayA is a modern web GUI client for V2Ray",
      "url": "https://github.com/v2rayA/v2rayA",
      "arch": ["amd64", "armhf", "armv7", "aarch64"],
      "startup": "services",
      "boot": "auto",
      "host_network": true,
      "ports": {
        "2017/tcp": 2017
      },
      "map": [
        "share:rw",
        "config:rw",
        "addon_config:/etc/v2raya:rw"
      ],
      "docker": {
        "privileged": true
      },
      "options": {
        "v2ray_version": "latest",
        "v2raya_version": "latest",
        "username": "admin",
        "password": "admin"
      },
      "schema": {
        "v2ray_version": "str",
        "v2raya_version": "str",
        "username": "str",
        "password": "str"
      }
    }
  ]
}