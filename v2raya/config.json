{
  "name": "v2rayA",
  "version": "v2.2.5",
  "slug": "v2raya",
  "description": "v2rayA 代理客户端（适配HA）",
  "url": "https://github.com/v2rayA/v2rayA",
  "arch": ["amd64", "arm64", "armv7"],
  "startup": "application",
  "boot": "auto",
  "ports": {
    "2017/tcp": 2017,
    "20170/tcp": 20170
  },
  "ports_description": {
    "2017/tcp": "Web管理界面",
    "20170/tcp": "SOCKS5代理端口"
  },
  "map": ["config:rw"],
  "privileged": ["NET_ADMIN"],
  "host_network": false,
  "image": "mzz2017/v2raya:latest",
  "environment": {
    "V2RAYA_LOG_LEVEL": "info",
    "V2RAYA_ADDRESS": "0.0.0.0:2017"
  }
}